# Populated by `npm run upload` on first run (saved automatically by @contentful/app-scripts)
CONTENTFUL_APP_DEF_ID=

# Personal Access Token with org-level app management scope
# Create at: https://app.contentful.com/account/profile/cma_tokens
CONTENTFUL_MANAGEMENT_TOKEN=

# URL of the Lambda/API Gateway endpoint (no trailing slash).
# Deployed stack output ApiUrl — see aws/samconfig.toml
# When set, the Audit Log tab fetches real audit logs from S3 via this backend.
VITE_AUDIT_API_URL=https://mpl8x3qyf2.execute-api.us-east-1.amazonaws.com
